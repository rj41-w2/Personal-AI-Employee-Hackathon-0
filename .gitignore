__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
*.egg
.eggs/

# --- Virtual Environments ---
.venv/
venv/
ENV/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS Generated ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# --- UV / Package Manager ---
uv.lock
