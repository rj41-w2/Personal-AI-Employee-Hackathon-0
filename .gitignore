# ======================================
# Personal AI Employee - .gitignore
# ======================================

# --- Secrets & Credentials (CRITICAL) ---
.env
.env.local
.env.*.local
credentials.json
token.json
*.pem

# --- AI Employee Vault (Data Privacy) ---
# Ignore all contents but keep directory structure
AI_Employee_Vault/**/*
!AI_Employee_Vault/
!AI_Employee_Vault/**/.gitkeep
AI_Employee_Vault/.obsidian/
AI_Employee_Vault/loop_memory.json

# --- Dashboard Node Modules ---
ai-dashboard/node_modules/
ai-dashboard/.next/
ai-dashboard/out/
ai-dashboard/build/
ai-dashboard/.env.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
*.egg
.eggs/

# --- Virtual Environments ---
.venv/
venv/
ENV/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS Generated ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# --- UV / Package Manager ---
uv.lock
