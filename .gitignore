# ======================================
# Personal AI Employee - .gitignore
# ======================================

# --- Secrets & Credentials (CRITICAL) ---
.env
credentials.json
token.json

# --- AI Employee Vault (Personal Data) ---
# Ignore all contents but preserve the folder structure via .gitkeep
AI_Employee_Vault/Needs_Action/email/*
AI_Employee_Vault/Needs_Action/linkedin/*
AI_Employee_Vault/Pending_Approval/email/*
AI_Employee_Vault/Pending_Approval/linkedin/*
AI_Employee_Vault/Approved/email/*
AI_Employee_Vault/Approved/linkedin/*
AI_Employee_Vault/Done/email/*
AI_Employee_Vault/Done/linkedin/*
AI_Employee_Vault/Archive/email/*
AI_Employee_Vault/Archive/linkedin/*
AI_Employee_Vault/Plans/*
AI_Employee_Vault/Inbox/*
AI_Employee_Vault/Dashboard.md

# Keep the .gitkeep files that preserve directory structure
!AI_Employee_Vault/**/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
*.egg
.eggs/

# --- Virtual Environments ---
.venv/
venv/
ENV/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS Generated ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# --- UV / Package Manager ---
uv.lock
